{
  "name": "quant-trading-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Polished, customizable quant trading competition platform (market making, directional, multi-event) built for thousands of concurrent users.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @qtp/db db:generate",
    "db:migrate": "pnpm --filter @qtp/db db:migrate",
    "db:push": "pnpm --filter @qtp/db db:push",
    "db:seed": "pnpm --filter @qtp/db db:seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "deploy:changed": "./scripts/deploy-changed.sh",
    "deploy:all": "BUILD_ALL=1 SKIP_PROVISION=1 ./scripts/azure-deploy.sh",
    "deploy:registry": "./scripts/registry-vm-deploy.sh",
    "setup:acr": "./scripts/setup-ci-registry.sh",
    "setup:github-secrets": "./scripts/setup-github-secrets.sh",
    "deploy:services": "./scripts/changed-services.sh --git"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
